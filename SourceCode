using System;
using System.Collections;
using System.Collections.Generic;
using UnityEngine;
using BepInEx;

namespace BeyondSandboxFingerPhysics
{
    [BepInPlugin("com.expertdev.gorillatag.fingerphysics", "Beyond Sandbox Finger Physics", "3.2.0")]
    public class Plugin : BaseUnityPlugin
    {
        private void Start()
        {
            StartCoroutine(WaitForRigInitialization());
        }

        private IEnumerator WaitForRigInitialization()
        {
            while (GorillaTagger.Instance == null || GorillaTagger.Instance.offlineVRRig == null || GorillaLocomotion.GTPlayer.Instance == null)
            {
                yield return null;
            }

            GorillaTagger.Instance.offlineVRRig.gameObject.AddComponent<FingerPhysicsManager>();
        }
    }

    public enum PhantomType { Neutral, Left, Right }

    public class PhantomCol
    {
        public Collider collider;
        public PhantomType type;
    }

    [DefaultExecutionOrder(10000)] 
    public class FingerPhysicsManager : MonoBehaviour
    {
        private List<FingerChain> fingers = new List<FingerChain>();
        private List<PhantomCol> phantomColliders = new List<PhantomCol>();

        private readonly string[][] fingerPaths = new string[][]
        {
            new string[] { "rig/hand.L/palm.01.L/f_index.01.L", "rig/hand.L/palm.01.L/f_index.01.L/f_index.02.L", "rig/hand.L/palm.01.L/f_index.01.L/f_index.02.L/f_index.03.L", "rig/hand.L/palm.01.L/f_index.01.L/f_index.02.L/f_index.03.L/f_index.03.L_end" },
            new string[] { "rig/hand.L/palm.02.L/f_middle.01.L", "rig/hand.L/palm.02.L/f_middle.01.L/f_middle.02.L", "rig/hand.L/palm.02.L/f_middle.01.L/f_middle.02.L/f_middle.03.L", "rig/hand.L/palm.02.L/f_middle.01.L/f_middle.02.L/f_middle.03.L/f_middle.03.L_end" },
            new string[] { "rig/hand.L/palm.01.L/thumb.01.L", "rig/hand.L/palm.01.L/thumb.01.L/thumb.02.L", "rig/hand.L/palm.01.L/thumb.01.L/thumb.02.L/thumb.03.L", "rig/hand.L/palm.01.L/thumb.01.L/thumb.02.L/thumb.03.L/thumb.03.L_end" },
            
            new string[] { "rig/hand.R/palm.01.R/f_index.01.R", "rig/hand.R/palm.01.R/f_index.01.R/f_index.02.R", "rig/hand.R/palm.01.R/f_index.01.R/f_index.02.R/f_index.03.R", "rig/hand.R/palm.01.R/f_index.01.R/f_index.02.R/f_index.03.R/f_index.03.R_end" },
            new string[] { "rig/hand.R/palm.02.R/f_middle.01.R", "rig/hand.R/palm.02.R/f_middle.01.R/f_middle.02.R", "rig/hand.R/palm.02.R/f_middle.01.R/f_middle.02.R/f_middle.03.R", "rig/hand.R/palm.02.R/f_middle.01.R/f_middle.02.R/f_middle.03.R/f_middle.03.R_end" },
            new string[] { "rig/hand.R/palm.01.R/thumb.01.R", "rig/hand.R/palm.01.R/thumb.01.R/thumb.02.R", "rig/hand.R/palm.01.R/thumb.01.R/thumb.02.R/thumb.03.R", "rig/hand.R/palm.01.R/thumb.01.R/thumb.02.R/thumb.03.R/thumb.03.R_end" }
        };

        private void Start()
        {
            Transform rigRoot = transform;

            Collider[] rigColliders = GetComponentsInChildren<Collider>(true);
            Collider[] locomotionColliders = GorillaLocomotion.GTPlayer.Instance.GetComponentsInChildren<Collider>(true);

            int playerLayer = GorillaLocomotion.GTPlayer.Instance.bodyCollider != null ? 
                              GorillaLocomotion.GTPlayer.Instance.bodyCollider.gameObject.layer : 8;

            CreatePhantomColliders(rigRoot, locomotionColliders, rigColliders, true);

            foreach (string[] pathChain in fingerPaths)
            {
                Transform[] bones = new Transform[pathChain.Length];
                bool valid = true;

                for (int i = 0; i < pathChain.Length; i++)
                {
                    Transform bone = rigRoot.Find(pathChain[i]);
                    if (bone == null)
                    {
                        valid = false;
                        break;
                    }
                    bones[i] = bone;
                }

                if (valid)
                {
                    FingerChain chain = new FingerChain();
                    chain.Initialize(bones, playerLayer, rigColliders, locomotionColliders);
                    fingers.Add(chain);
                }
            }

            StartCoroutine(MultiplayerScanner());
        }

        private IEnumerator MultiplayerScanner()
        {
            HashSet<VRRig> processedRigs = new HashSet<VRRig>();
            if (GorillaTagger.Instance != null && GorillaTagger.Instance.offlineVRRig != null)
            {
                processedRigs.Add(GorillaTagger.Instance.offlineVRRig);
            }

            while (true)
            {
                yield return new WaitForSeconds(2f);
                
                VRRig[] allRigs = FindObjectsOfType<VRRig>();
                foreach (VRRig rig in allRigs)
                {
                    if (rig == null || !rig.gameObject.activeInHierarchy) continue;
                    if (!processedRigs.Contains(rig))
                    {
                        Collider[] locCols = GorillaLocomotion.GTPlayer.Instance.GetComponentsInChildren<Collider>(true);
                        Collider[] rigCols = rig.GetComponentsInChildren<Collider>(true);
                        
                        CreatePhantomColliders(rig.transform, locCols, rigCols, false);
                        processedRigs.Add(rig);
                    }
                }
            }
        }

        private void CreatePhantomColliders(Transform rigRoot, Collider[] locCols, Collider[] rigCols, bool isLocal)
        {
            Transform head = rigRoot.Find("rig/head");
            Transform body = rigRoot.Find("rig/body_pivot/body");
            
            Transform upperL = rigRoot.Find("rig/body_pivot/shoulder.L/upper_arm.L");
            Transform lowerL = rigRoot.Find("rig/body_pivot/shoulder.L/upper_arm.L/forearm.L");
            Transform handL = rigRoot.Find("rig/hand.L");

            Transform upperR = rigRoot.Find("rig/body_pivot/shoulder.R/upper_arm.R");
            Transform lowerR = rigRoot.Find("rig/body_pivot/shoulder.R/upper_arm.R/forearm.R");
            Transform handR = rigRoot.Find("rig/hand.R");

            PhantomType typeL = isLocal ? PhantomType.Left : PhantomType.Neutral;
            PhantomType typeR = isLocal ? PhantomType.Right : PhantomType.Neutral;
            PhantomType typeN = PhantomType.Neutral;

            AddPhantomCapsule(body, head, 0.18f, typeN, locCols, rigCols); 
            AddPhantomSphere(body, 0.2f, new Vector3(0, -0.1f, 0), typeN, locCols, rigCols); 
            AddPhantomSphere(head, 0.15f, Vector3.zero, typeN, locCols, rigCols); 

            AddPhantomCapsule(upperL, lowerL, 0.08f, typeL, locCols, rigCols); 
            AddPhantomCapsule(lowerL, handL, 0.07f, typeL, locCols, rigCols);  
            AddPhantomSphere(handL, 0.08f, new Vector3(0, -0.04f, 0), typeL, locCols, rigCols); 

            AddPhantomCapsule(upperR, lowerR, 0.08f, typeR, locCols, rigCols);
            AddPhantomCapsule(lowerR, handR, 0.07f, typeR, locCols, rigCols);
            AddPhantomSphere(handR, 0.08f, new Vector3(0, -0.04f, 0), typeR, locCols, rigCols);

            foreach (string[] pathChain in fingerPaths)
            {
                bool isLeft = pathChain[0].Contains(".L");
                PhantomType pType = isLocal ? (isLeft ? PhantomType.Left : PhantomType.Right) : PhantomType.Neutral;

                for (int i = 0; i < pathChain.Length - 1; i++)
                {
                    Transform start = rigRoot.Find(pathChain[i]);
                    Transform end = rigRoot.Find(pathChain[i+1]);
                    if (start != null && end != null)
                    {
                        AddPhantomCapsule(start, end, 0.015f, pType, locCols, rigCols);
                    }
                }
                
                Transform tip = rigRoot.Find(pathChain[pathChain.Length - 1]);
                if (tip != null)
                {
                    AddPhantomSphere(tip, 0.015f, Vector3.zero, pType, locCols, rigCols);
                }
            }
        }

        private void AddPhantomSphere(Transform parent, float radius, Vector3 offset, PhantomType type, Collider[] locCols, Collider[] rigCols)
        {
            if (parent == null) return;
            GameObject go = new GameObject("PhantomSphere_" + parent.name);
            go.transform.SetParent(parent, false);
            go.transform.localPosition = offset;
            go.layer = 2; 
            
            SphereCollider col = go.AddComponent<SphereCollider>();
            col.radius = radius;

            Rigidbody rb = go.AddComponent<Rigidbody>();
            rb.isKinematic = true;
            rb.useGravity = false;

            foreach (Collider lc in locCols) if (lc != null) Physics.IgnoreCollision(col, lc, true);
            foreach (Collider rc in rigCols) if (rc != null) Physics.IgnoreCollision(col, rc, true);

            phantomColliders.Add(new PhantomCol { collider = col, type = type });
        }

        private void AddPhantomCapsule(Transform start, Transform end, float radius, PhantomType type, Collider[] locCols, Collider[] rigCols)
        {
            if (start == null || end == null) return;

            GameObject go = new GameObject("PhantomCapsule_" + start.name);
            go.transform.SetParent(start, false);
            
            float length = Vector3.Distance(start.position, end.position);
            go.transform.position = (start.position + end.position) / 2f;
            go.transform.LookAt(end);
            
            go.layer = 2; 
            
            CapsuleCollider col = go.AddComponent<CapsuleCollider>();
            col.direction = 2; 
            col.radius = radius;
            col.height = length + (radius * 2);

            Rigidbody rb = go.AddComponent<Rigidbody>();
            rb.isKinematic = true;
            rb.useGravity = false;

            foreach (Collider lc in locCols) if (lc != null) Physics.IgnoreCollision(col, lc, true);
            foreach (Collider rc in rigCols) if (rc != null) Physics.IgnoreCollision(col, rc, true);

            phantomColliders.Add(new PhantomCol { collider = col, type = type });
        }

        private void FixedUpdate()
        {
            foreach (FingerChain finger in fingers)
            {
                finger.FixedUpdatePhysics();
            }

            foreach (FingerChain finger in fingers)
            {
                finger.ResolveCustomCollisions(phantomColliders, fingers);
            }
        }

        private void LateUpdate()
        {
            foreach (FingerChain finger in fingers)
            {
                finger.UpdateAnimationTargets();
            }

            foreach (FingerChain finger in fingers)
            {
                finger.SolveAndApplyVisuals();
            }
        }
    }

    public class FingerChain
    {
        public bool isLeftHand;

        private Transform[] visualBones;
        private float[] boneLengths;
        public Rigidbody[] proxies;
        public Collider[] proxyColliders;
        
        private Vector3[] targetPositions;
        private Quaternion[] targetRotations;
        private Quaternion[] targetLocalRotations;
        private Quaternion[] smoothedLocalRotations;

        private Vector3 lastBasePosition;

        private const float PROXY_RADIUS = 0.012f; 
        private const float TRACKING_FORCE = 80f;  
        private const float MAX_BEND_ANGLE = 45f;  

        public void Initialize(Transform[] bones, int playerLayer, Collider[] rigColliders, Collider[] locomotionColliders)
        {
            visualBones = bones;
            int count = bones.Length;
            
            isLeftHand = bones[0].name.Contains(".L");

            boneLengths = new float[count - 1];
            proxies = new Rigidbody[count];
            proxyColliders = new Collider[count];
            targetPositions = new Vector3[count];
            targetRotations = new Quaternion[count];
            targetLocalRotations = new Quaternion[count];
            smoothedLocalRotations = new Quaternion[count];

            lastBasePosition = bones[0].position;

            for (int i = 0; i < count; i++)
            {
                if (i < count - 1)
                {
                    boneLengths[i] = Vector3.Distance(bones[i].position, bones[i + 1].position);
                }

                smoothedLocalRotations[i] = bones[i].localRotation;

                GameObject proxyObj = new GameObject("PhysicsProxy_" + bones[i].name);
                proxyObj.layer = playerLayer; 

                SphereCollider col = proxyObj.AddComponent<SphereCollider>();
                col.radius = PROXY_RADIUS;
                
                col.material = new PhysicsMaterial 
                { 
                    frictionCombine = PhysicsMaterialCombine.Minimum, 
                    bounceCombine = PhysicsMaterialCombine.Minimum, 
                    staticFriction = 0f, 
                    dynamicFriction = 0f, 
                    bounciness = 0f 
                };
                proxyColliders[i] = col;

                Rigidbody rb = proxyObj.AddComponent<Rigidbody>();
                rb.mass = 0.005f; 
                rb.useGravity = false;
                rb.isKinematic = false;
                rb.collisionDetectionMode = CollisionDetectionMode.ContinuousDynamic;
                rb.interpolation = RigidbodyInterpolation.Interpolate;
                rb.linearDamping = 25f;
                rb.angularDamping = 25f;
                rb.sleepThreshold = 0f; 

                proxyObj.transform.position = bones[i].position;
                proxies[i] = rb;

                foreach (Collider locCol in locomotionColliders) if (locCol != null) Physics.IgnoreCollision(col, locCol, true);
                foreach (Collider rigCol in rigColliders) if (rigCol != null) Physics.IgnoreCollision(col, rigCol, true);
            }

            for (int i = 0; i < count; i++)
            {
                for (int j = i + 1; j < count; j++)
                {
                    Physics.IgnoreCollision(proxyColliders[i], proxyColliders[j], true);
                }
            }
        }

        public void UpdateAnimationTargets()
        {
            for (int i = 0; i < visualBones.Length; i++)
            {
                targetPositions[i] = visualBones[i].position;
                targetRotations[i] = visualBones[i].rotation;
                targetLocalRotations[i] = visualBones[i].localRotation;
            }
        }

        public void FixedUpdatePhysics()
        {
            int count = proxies.Length;
            float dt = Time.fixedDeltaTime;

            Vector3 handVel = Vector3.zero;
            if (dt > 0f)
            {
                handVel = (targetPositions[0] - lastBasePosition) / dt;
                handVel = Vector3.ClampMagnitude(handVel, 15f);
                lastBasePosition = targetPositions[0];
            }

            proxies[0].MovePosition(targetPositions[0]);
            proxies[0].linearVelocity = handVel;

            Vector3 tipOffset = proxies[count - 1].position - targetPositions[count - 1];

            for (int i = 1; i < count; i++)
            {
                Vector3 targetPos = targetPositions[i];

                if (i < count - 1)
                {
                    float weight = (i == count - 2) ? 0.4f : 0.2f;
                    Vector3 pull = tipOffset * weight;
                    
                    Vector3 boneDir = (targetPositions[i] - targetPositions[i - 1]).normalized;
                    Vector3 pullAlongBone = Vector3.Project(pull, boneDir);
                    if (Vector3.Dot(pullAlongBone, boneDir) < 0)
                    {
                        pull -= pullAlongBone;
                    }
                    
                    targetPos += pull;
                }

                Vector3 error = targetPos - proxies[i].position;
                
                if (error.sqrMagnitude > 0.04f) 
                {
                    proxies[i].position = targetPos;
                    proxies[i].linearVelocity = handVel;
                }
                else
                {
                    Vector3 trackingVel = error * TRACKING_FORCE;
                    trackingVel = Vector3.ClampMagnitude(trackingVel, 4f); 
                    proxies[i].linearVelocity = handVel + trackingVel;
                }
            }
        }

        public void ResolveCustomCollisions(List<PhantomCol> phantoms, List<FingerChain> allFingers)
        {
            for (int i = 1; i < proxies.Length; i++)
            {
                for (int p = 0; p < phantoms.Count; p++)
                {
                    PhantomCol phantom = phantoms[p];
                    if (phantom.collider == null || !phantom.collider.gameObject.activeInHierarchy) continue;
                    
                    if (phantom.type == PhantomType.Neutral || 
                       (isLeftHand && phantom.type == PhantomType.Right) || 
                       (!isLeftHand && phantom.type == PhantomType.Left))
                    {
                        Vector3 dir;
                        float dist;
                        if (Physics.ComputePenetration(
                            proxyColliders[i], proxies[i].position, proxies[i].rotation,
                            phantom.collider, phantom.collider.transform.position, phantom.collider.transform.rotation,
                            out dir, out dist))
                        {
                            proxies[i].position += dir * dist;
                        }
                    }
                }

                foreach (FingerChain otherChain in allFingers)
                {
                    if (!this.isLeftHand || otherChain.isLeftHand) continue; 
                    
                    for (int j = 1; j < otherChain.proxies.Length; j++)
                    {
                        if (otherChain.proxyColliders[j] == null) continue;

                        Vector3 dir;
                        float dist;
                        if (Physics.ComputePenetration(
                            proxyColliders[i], proxies[i].position, proxies[i].rotation,
                            otherChain.proxyColliders[j], otherChain.proxies[j].position, otherChain.proxies[j].rotation,
                            out dir, out dist))
                        {
                            proxies[i].position += dir * (dist * 0.5f);
                            otherChain.proxies[j].position -= dir * (dist * 0.5f);
                        }
                    }
                }
            }
        }

        public void SolveAndApplyVisuals()
        {
            int count = visualBones.Length;

            visualBones[0].position = targetPositions[0];
            visualBones[0].rotation = targetRotations[0];

            for (int i = 0; i < count - 1; i++)
            {
                if (boneLengths[i] < 0.015f)
                {
                    smoothedLocalRotations[i] = Quaternion.Slerp(smoothedLocalRotations[i], targetLocalRotations[i], Time.deltaTime * 40f);
                    visualBones[i].localRotation = smoothedLocalRotations[i];
                    
                    Vector3 animDirBypass = visualBones[i].rotation * Quaternion.Inverse(targetRotations[i]) * (targetPositions[i + 1] - targetPositions[i]);
                    visualBones[i + 1].position = visualBones[i].position + animDirBypass.normalized * boneLengths[i];
                    continue;
                }

                Vector3 currentPos = visualBones[i].position;
                Vector3 proxyNextPos = proxies[i + 1].position;
                
                Vector3 dirToProxy = proxyNextPos - currentPos;
                Vector3 animDir = targetPositions[i + 1] - targetPositions[i];

                float dist = dirToProxy.magnitude;
                if (dist < 0.001f) dirToProxy = animDir.normalized;
                else dirToProxy /= dist;

                animDir.Normalize();

                if (i == count - 2)
                {
                    dirToProxy = Vector3.Lerp(dirToProxy, animDir, 0.8f).normalized; 
                }

                float angle = Vector3.Angle(animDir, dirToProxy);
                if (angle > MAX_BEND_ANGLE)
                {
                    Vector3 axis = Vector3.Cross(animDir, dirToProxy);
                    if (axis.sqrMagnitude < 0.001f) axis = targetRotations[i] * Vector3.right; 
                    dirToProxy = Quaternion.AngleAxis(MAX_BEND_ANGLE, axis.normalized) * animDir;
                }

                Quaternion targetWorldRot = Quaternion.FromToRotation(animDir, dirToProxy) * targetRotations[i];
                Quaternion targetLocalRot = Quaternion.Inverse(visualBones[i].parent.rotation) * targetWorldRot;

                smoothedLocalRotations[i] = Quaternion.Slerp(smoothedLocalRotations[i], targetLocalRot, Time.deltaTime * 40f);
                visualBones[i].localRotation = smoothedLocalRotations[i];

                Vector3 appliedDir = visualBones[i].rotation * Quaternion.Inverse(targetRotations[i]) * animDir;
                visualBones[i + 1].position = currentPos + appliedDir.normalized * boneLengths[i];
            }
            
            smoothedLocalRotations[count - 1] = Quaternion.Slerp(smoothedLocalRotations[count - 1], targetLocalRotations[count - 1], Time.deltaTime * 40f);
            visualBones[count - 1].localRotation = smoothedLocalRotations[count - 1];
        }
    }
}
